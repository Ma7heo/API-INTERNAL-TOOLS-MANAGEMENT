# =============================================
# DATABASE CONFIGURATION - INTERNAL TOOLS TEST
# =============================================

# PostgreSQL Configuration  
POSTGRES_DATABASE=nom_de_la_base
POSTGRES_USER=votre_utilisateur
POSTGRES_PASSWORD=votre_mot_de_passe_secret
POSTGRES_PORT=5432

# Admin Tools
PGADMIN_PORT=8081
PGADMIN_EMAIL=admin@votre_domaine.com
PGADMIN_PASSWORD=mot_de_passe_admin_secret

# =============================================
# APPLICATION CONNECTION STRING (Utilisé par FastAPI)
# =============================================
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://utilisateur:mot_de_passe@localhost:5432/nom_de_la_base